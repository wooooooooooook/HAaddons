{
  "name": "Heatmap Builder",
  "version": "0.4.3",
  "slug": "heatmapbuilder",
  "url": "https://github.com/wooooooooooook/HeatMapBuilder/tree/main/hassio-addon",
  "description": "평면도와 센서위치를 기반으로 센서 값 히트맵을 그립니다.",
  "arch": [
    "aarch64",
    "amd64"
  ],
  "image": "nubiz/heatmapbuilder",
  "map": [
    {
      "type": "homeassistant_config",
      "read_only": false,
      "path": "/homeassistant"
    }
  ],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "hassio_api": true,
  "auth_api": true,
  "homeassistant_api": true,
  "options": {
    "log_level": "debug"
  },
  "schema": {
    "log_level": "list(trace|debug|info|warning|error|fatal)"
  },
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:floor-plan",
  "ports": {
    "8099/tcp": null
  }
}
